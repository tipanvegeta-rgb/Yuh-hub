local faInfEnabled    = false
local faInfConnection = nil
local faInfBtn = addBtn("âš¡  Fast Attack INFINITO  [ OFF ]", C.gold, rangoPage)
faInfBtn.MouseButton1Click:Connect(function()
    faInfEnabled = not faInfEnabled
    setToggleStyle(faInfBtn, getDot(faInfBtn), getStroke(faInfBtn), faInfEnabled,
        "âš¡  Fast Attack INFINITO  [ ON ]", "âš¡  Fast Attack INFINITO  [ OFF ]",
        C.green, C.gold)
    if faInfEnabled then
        if faInfConnection then task.cancel(faInfConnection) end
        faInfConnection = task.spawn(function()
            while faInfEnabled do
                RunService.Stepped:Wait()
                local myChar = Players.LocalPlayer.Character
                local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
                if not myHRP then continue end
                local targets = {}
                for _, player in pairs(Players:GetPlayers()) do
                    if player ~= Players.LocalPlayer and player.Character then
                        local hum = player.Character:FindFirstChild("Humanoid")
                        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                        if hum and hrp and hum.Health > 0 then table.insert(targets, player.Character) end
                    end
                end
                local enemies = workspace:FindFirstChild("Enemies")
                if enemies then
                    for _, npc in pairs(enemies:GetChildren()) do
                        local hum = npc:FindFirstChild("Humanoid")
                        local hrp = npc:FindFirstChild("HumanoidRootPart")
                        if hum and hrp and hum.Health > 0 then table.insert(targets, npc) end
                    end
                end
                if #targets > 0 then AttackMultipleTargets(targets) end
            end
        end)
    else
        if faInfConnection then task.cancel(faInfConnection) end
    end
end)

