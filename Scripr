local function createTab(label, icon, page)
    local btn = Instance.new("TextButton", tabRow)
    btn.Size             = UDim2.new(0, 68, 1, 0)
    btn.Text             = icon .. " " .. label
    btn.BackgroundColor3 = C.card
    btn.TextColor3       = C.textDim
    btn.Font             = Enum.Font.GothamBold
    btn.TextSize         = 8
    btn.AutoButtonColor  = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    local stroke = Instance.new("UIStroke", btn)
    stroke.Color     = C.border
    stroke.Thickness = 1

    local function setActive(active)
        if active then
            TweenService:Create(btn, TweenInfo.new(0.18), {BackgroundColor3 = C.btnHover, TextColor3 = C.accent2}):Play()
            stroke.Color     = C.accent
            stroke.Thickness = 1.2
        else
            TweenService:Create(btn, TweenInfo.new(0.18), {BackgroundColor3 = C.card, TextColor3 = C.textDim}):Play()
            stroke.Color     = C.border
            stroke.Thickness = 1
        end
    end

    btn.MouseButton1Click:Connect(function()
        if activeTabBtn then activeTabBtn[2](false) end
        activeTabBtn = {btn, setActive}
        setActive(true)
        showPage(page)
    end)
    btn.MouseEnter:Connect(function()
        if activePage ~= page then TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = C.btnBg}):Play() end
    end)
    btn.MouseLeave:Connect(function()
        if activePage ~= page then TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = C.card}):Play() end
    end)
    return {btn, setActive}
end

