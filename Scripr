local function addBtn(txt, accentColor, parent)
    local btn = Instance.new("TextButton", parent)
    btn.Size             = UDim2.new(0.96, 0, 0, 38)
    btn.BackgroundColor3 = C.btnBg
    btn.Text             = txt
    btn.TextColor3       = C.text
    btn.Font             = Enum.Font.GothamBold
    btn.TextSize         = 11
    btn.AutoButtonColor  = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 9)
    local stroke = Instance.new("UIStroke", btn)
    stroke.Color        = accentColor or C.border
    stroke.Thickness    = 1
    stroke.Transparency = 0.4
    local dot = Instance.new("Frame", btn)
    dot.Size             = UDim2.new(0, 3, 0.5, 0)
    dot.Position         = UDim2.new(0, 0, 0.25, 0)
    dot.BackgroundColor3 = accentColor or C.accent
    dot.BorderSizePixel  = 0
    Instance.new("UICorner", dot).CornerRadius = UDim.new(0, 4)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.14), {BackgroundColor3 = C.btnHover}):Play()
        stroke.Transparency = 0
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.14), {BackgroundColor3 = C.btnBg}):Play()
        stroke.Transparency = 0.4
    end)
    return btn
end

local function setToggleStyle(btn, dot, stroke, enabled, labelOn, labelOff, colorOn, colorOff)
    btn.Text             = enabled and labelOn or labelOff
    local col            = enabled and colorOn or colorOff
    dot.BackgroundColor3 = col
    stroke.Color         = col
    TweenService:Create(btn, TweenInfo.new(0.15), {TextColor3 = enabled and col or C.text}):Play()
end

local function getDot(btn)    return btn:FindFirstChildWhichIsA("Frame") end
local function getStroke(btn) return btn:FindFirstChildWhichIsA("UIStroke") end

