-- Auto Farm / Mine
local function StartAutoFarm()
    if MiningLoopConn then task.cancel(MiningLoopConn) end
    MiningLoopConn = task.spawn(function()
        while AutoFarmEnabled do
            pcall(function()
                local char = Players.LocalPlayer.Character
                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                local oreKeywords = {
                    "ore","rock","crystal","gem","coal","iron",
                    "gold","diamond","mine","stone","ruby","emerald","amethyst"
                }
                for _, part in pairs(workspace:GetDescendants()) do
                    if not AutoFarmEnabled then break end
                    if part:IsA("BasePart") or part:IsA("MeshPart") or part:IsA("UnionOperation") then
                        local n = part.Name:lower()
                        for _, kw in pairs(oreKeywords) do
                            if n:find(kw) then
                                hrp.CFrame = part.CFrame + Vector3.new(0, 4, 0)
                                task.wait(0.07)
                                -- Disparar remotes de minerÃ­a
                                pcall(function()
                                    for _, rem in pairs(ReplicatedStorage:GetDescendants()) do
                                        if rem:IsA("RemoteEvent") then
                                            local rn = rem.Name:lower()
                                            if rn:find("mine") or rn:find("hit") or rn:find("break") or rn:find("collect") or rn:find("click") then
                                                rem:FireServer(part)
                                            end
                                        end
                                        if rem:IsA("RemoteFunction") then
                                            local rn = rem.Name:lower()
                                            if rn:find("mine") or rn:find("collect") then
                                                pcall(function() rem:InvokeServer(part) end)
                                            end
                                        end
                                    end
                                end)
                                task.wait(0.05)
                                break
                            end
                        end
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
end

-- Auto Sell
local function StartAutoSell()
    if SellLoopConn then task.cancel(SellLoopConn) end
    SellLoopConn = task.spawn(function()
        while AutoSellEnabled do
            pcall(function()
                local char = Players.LocalPlayer.Character
                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                -- Teletransporte a zona de venta
                local sellKeywords = {"sell","shop","conveyor","dropper","deposit","cashier"}
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj:IsA("BasePart") then
                        local n = obj.Name:lower()
                        for _, kw in pairs(sellKeywords) do
                            if n:find(kw) then
                                hrp.CFrame = obj.CFrame + Vector3.new(0, 4, 0)
                                task.wait(0.3)
                                break
                            end
                        end
                    end
                end
                -- Disparar remotes de venta
                for _, rem in pairs(ReplicatedStorage:GetDescendants()) do
                    if rem:IsA("RemoteEvent") then
                        local rn = rem.Name:lower()
                        if rn:find("sell") or rn:find("cash") or rn:find("money") or rn:find("earn") then
                            rem:FireServer()
                            task.wait(0.1)
                        end
                    end
                end
            end)
            task.wait(1.5)
        end
    end)
end

-- Auto Upgrade
local function StartAutoUpgrade()
    if UpgradeLoopConn then task.cancel(UpgradeLoopConn) end
    UpgradeLoopConn = task.spawn(function()
        while AutoUpgradeEnabled do
            pcall(function()
                for _, rem in pairs(ReplicatedStorage:GetDescendants()) do
                    if rem:IsA("RemoteEvent") then
                        local rn = rem.Name:lower()
                        if rn:find("upgrade") or rn:find("buy") or rn:find("purchase") or rn:find("level") then
                            rem:FireServer()
                            task.wait(0.2)
                        end
                    end
                    if rem:IsA("RemoteFunction") then
                        local rn = rem.Name:lower()
                        if rn:find("upgrade") or rn:find("buy") then
                            pcall(function() rem:InvokeServer() end)
                            task.wait(0.2)
                        end
                    end
                end
            end)
            task.wait(2)
        end
    end)
end

